{
    "name": "minimalist-theme",
    "dataColors": [
        "#5C86A8",
        "#BBBBBE",
        "#333333",
        "#006400",
        "#A1343C",
        "#C8C6C4",
        "#D9B300",
        "#D64550"
    ],
    "neutral": "#FFFFFF",
    "good": "#006400",
    "bad": "#A1343C",
    "textClasses": {
        "label": {
            "fontFace": "wf_standard-font"
        },
        "title": {
            "fontSize": 14
        },
        "header": {
            "fontFace": "wf_standard-font"
        },
        "callout": {
            "fontSize": 15,
            "fontFace": "wf_standard-font"
        }
    },
    "visualStyles": {
        "*": {
            "*": {
                "border": [
                    {
                        "show": false
                    }
                ]
            }
        },
        "page": {
            "*": {
                "outspace": [
                    {
                        "transparency": 0
                    }
                ]
            }
        }
    }
}