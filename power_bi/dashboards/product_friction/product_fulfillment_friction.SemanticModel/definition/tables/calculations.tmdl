	measure lead_time_4w_rolling_avg = ```
			
			    AVERAGEX(
			        DATESINPERIOD('calendar_date'[Date], LASTDATE('calendar_date'[Date]), -28, DAY),
			        [avg_lead_time]
			    )
			```
		displayFolder: _prerequisites_measures
		lineageTag: ac5f3a7d-a595-4994-a5cc-423eef53d7d4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure product_weight = ```
			
			LOOKUPVALUE(
			    product_dim[product_weight_g], 
			    product_dim[product_id_int], 
			    MAX(product_weekly_fact[product_id_int])
			)
			
			```
		displayFolder: visual_measures
		lineageTag: d800dd8c-ba8c-414b-a766-22e7a622834b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure product_volume_categ = ```
			
			LOOKUPVALUE(
			    product_dim[size_bucket], 
			    product_dim[product_id_int], 
			    MAX(product_weekly_fact[product_id_int])
			)
			```
		displayFolder: visual_measures
