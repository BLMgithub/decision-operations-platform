	measure item_rank = ```
			
			CALCULATE(
			    RANKX(
			        FILTER(
			            ALL(product_dim[product_id_int]),
			            [revenue_at_risk] > 0
			        ),                
			        [revenue_at_risk],
			        ,
			        DESC
			    )
			)
			```
		formatString: 0
		displayFolder: _paging_measures
		lineageTag: 30c6ee81-29ef-48da-9463-572a9d3eec88

	measure item_rank_filter = ```
			
			VAR _page = [paging_helper Value]
			VAR _page_size = [table_items Value]
			
			VAR item_rank = [item_rank]
			
			VAR _start = (_page - 1) * _page_size + 1
			VAR _end = _page * _page_size
			
			VAR is_in_range = 
			    IF(
			        item_rank >= _start && 
			        item_rank <= _end, 
			        1, 
			        0
			    )
			
			RETURN
			    is_in_range
			```
		formatString: 0
		displayFolder: _paging_measures
		lineageTag: a4903fad-285f-4ea3-81c0-4e0502076e79

	measure item_rank_string = CONCATENATE("#",[item_rank])
		displayFolder: _paging_measures
		lineageTag: 2bd6f813-81d9-40d3-b67e-8dd5bd0bbe75

	measure max_page =
			
			ROUNDUP(
			    DIVIDE(VALUE([product_at_risk]),  [table_items Value]),
			    0
			)
		displayFolder: _paging_measures
		lineageTag: eb2e2e69-5b90-495c-9f45-3d465ab363d6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure page_filter = ```
			
			VAR _total_items = VALUE([product_at_risk])
			VAR items_per_page = [table_items Value]
			VAR max_page = 
			    ROUNDUP(
			        DIVIDE(_total_items, items_per_page),
			        0
			    )
			VAR _page_filter =
			    IF(
			        paging_helper[paging_helper Value] <= max_page,
			        1, 0
			    )
			RETURN
			    _page_filter
			```
		formatString: 0
		displayFolder: _paging_measures
		lineageTag: 03fe11bf-0886-4946-9653-075bdafb6b5e

	measure current_viewed_filter =
			
			VAR _is_at_risk = [product_at_risk]
			VAR _is_on_page = [item_rank_filter]
			
			RETURN
			IF(
			    _is_at_risk = 1 && _is_on_page = 1,
			    "#5C86A8",
			    "#999999"
			)
		displayFolder: _paging_measures
		lineageTag: 316a0377-b240-41ce-88af-8867465643ca

	measure color_format_revenue_at_risk = DIVIDE([revenue_at_risk], [total_revenue])
		displayFolder: visual_measures
		lineageTag: dc3c0f2d-76fb-4ed8-a5fc-9591ccae5782

