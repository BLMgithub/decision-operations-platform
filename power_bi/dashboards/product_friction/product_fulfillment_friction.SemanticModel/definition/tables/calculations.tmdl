		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure lead_time_slippage =
			
			VAR delta = [current_lead_time] - [lead_time_4w_rolling_avg]
			RETURN
			    IF([is_outlier] = 1, delta, BLANK())
		displayFolder: _prerequisites_measures
		lineageTag: 82b9fa97-dff1-4b5c-8a0c-64a01514fcbd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure product_at_risk =
			
			COUNTROWS(
				FILTER(
					VALUES(product_dim[product_id_int]),
					[is_outlier]=1
				)
			)
		formatString: 0
		displayFolder: KPI_measures
		lineageTag: 201fa0cd-af5b-4254-82a1-4e1cc60a22f8

	measure lead_time_volatility = ```
			
			VAR at_risk_products =
				FILTER(
					VALUES(product_dim[product_id_int]),
					[is_outlier]=1
				)
			VAR result = 
			    CALCULATE(
			        STDEV.S(product_weekly_fact[weekly_avg_lead_time]),
			        at_risk_products
			    )
			RETURN
			    result
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI_measures
		lineageTag: ce579d10-b2ce-4756-b616-e86f30ddba73

	measure revenue_at_risk =
			
