	measure category_range_view = ```
			
			VAR highest_value =
			    MAXX(
			        ALL(product_dim[product_category_name]), 
			        [revenue_at_risk]
			    )
			
			VAR adjustment = highest_value * 1.05
			
			RETURN 
			    adjustment
			```
		displayFolder: visual_measures
		lineageTag: 70e2a94c-8098-4cbd-bb2b-fc2d01634053

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure is_outlier = ```
			
			
			VAR _slippage_threshold = [slippage_threshold Value]
			VAR _std_dev_boundary = [std_dev_boundary Value]
			
			VAR slippage_delta = [current_lead_time] - [lead_time_4w_rolling_avg]
			VAR is_meaningful = 
			    IF(
			        slippage_delta > _slippage_threshold, 
			        1, 0
			    )
			
			VAR _stddev =
			    CALCULATE(
			        STDEV.S(product_weekly_fact[weekly_avg_lead_time]),
			        ALLEXCEPT(product_weekly_fact, product_weekly_fact[product_id_int])
			    )
			
			VAR outlier_flags =
			    IF(
			        is_meaningful = 1 &&
			        [current_lead_time] > ([lead_time_4w_rolling_avg] + (_std_dev_boundary * _stddev)),
			        1, 0
			    )
			    
			RETURN
			    outlier_flags
			```
		formatString: 0
		displayFolder: _prerequisites_measures
		lineageTag: f8779455-7694-4bf2-ae1c-3b70bfb53cae

	measure current_lead_time = CALCULATE([avg_lead_time], calendar_date[Date])
		displayFolder: _prerequisites_measures
