	measure tooltip_highlight_top_3 =
			
			VAR state_rank =
			    RANKX(
			        ALLSELECTED(customer_dim[customer_state]),
			        [revenue_at_risk],
			        ,
			        DESC,
			        Dense
			    )
			RETURN
			    IF(state_rank <= 3, "#5C86A8", "#999999")
		displayFolder: visual_measures_tooltip
		lineageTag: fc1634de-7fbf-42bf-b9ec-5e5d5bd90d07

	measure tooltip_revenue_at_risk = ```
			
			    IF(
			        [revenue_at_risk] < 1000000, 
			        FORMAT([revenue_at_risk], "$#,##0, K"), 
