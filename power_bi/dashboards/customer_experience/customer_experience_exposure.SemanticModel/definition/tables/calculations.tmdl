	measure weighted_avg_delivery_delay = ```
			
			    DIVIDE(
			        SUMX(customer_weekly_fact, 
			        customer_weekly_fact[weekly_avg_delivery_delay] * customer_weekly_fact[weekly_order_count]),
			        [total_order],
			        0
			    )
			```
		displayFolder: visual_measures
		lineageTag: 6684ce45-9bf7-4eff-8f45-a10ec2ad61d0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure weighted_avg_approval_lag = ```
			
			    DIVIDE(
			        SUMX(customer_weekly_fact, 
			        customer_weekly_fact[weekly_avg_approval_lag] * customer_weekly_fact[weekly_order_count]),
			        [total_order],
			        0
			    )
			```
		displayFolder: visual_measures
		lineageTag: 03542da5-3b1c-49ac-8056-a658d882fcdd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure weighted_avg_lead_time = ```
			
			    DIVIDE(
			        SUMX(customer_weekly_fact,
			        customer_weekly_fact[weekly_avg_lead_time] * customer_weekly_fact[weekly_order_count]),
			        [total_order],
			        0
			    )
			```
		formatString: 0
		displayFolder: visual_measures
		lineageTag: 6dfd2456-af49-4f3b-913c-9039909bef88

	measure revenue_at_risk = ```
			
			VAR threshold = SELECTEDVALUE(delay_threshold_parameter[threshold_parameter], 3)
			
			VAR result = 
			    CALCULATE(
			        [total_revenue],
			        FILTER(
			            customer_weekly_fact,
			            customer_weekly_fact[weekly_avg_delivery_delay] >= threshold
			        )
			    )
			
			RETURN
			    IF(ISBLANK(result), 0, result)
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: KPI_measures
		lineageTag: 7d6c2e30-d1a2-46ea-af51-1d6601d9f72c

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure bubble_size_sensitivity = [revenue_at_risk] ^ 0.8
		displayFolder: visual_measures
		lineageTag: caa3369c-5a1f-4577-a068-cd847c2c1b70

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure active_customer_prev_month =
			
			CALCULATE(
			    DISTINCTCOUNT(customer_weekly_fact[customer_id_int]),
			    DATEADD(calendar_table[Date], -1, MONTH)
			)
		formatString: 0
		displayFolder: _prerequisite_measures
		lineageTag: a893c41b-892a-43e5-bb50-bf41dd80b942

	measure MoM_drop_off_customers = ```
			
			VAR prev_period_customer = 
			    CALCULATETABLE(
			        DISTINCT(customer_weekly_fact[customer_id_int]),
			        DATEADD(calendar_table[Date], -1, MONTH)
			    )
			VAR current_period_customers =
			    CALCULATETABLE(
			        DISTINCT(customer_weekly_fact[customer_id_int]),
			        calendar_table[Month Name] =  SELECTEDVALUE(calendar_table[Month Name])
			    )
			
			VAR lost_customers =
			    EXCEPT(prev_period_customer, current_period_customers)
			
			RETURN
			    COUNTROWS(lost_customers)
			```
		formatString: 0
		displayFolder: _prerequisite_measures
		lineageTag: dfcf63e0-f71b-4e42-b50b-e4a8b4589a9a

	measure MoM_drop_off_rate = DIVIDE([MoM_drop_off_customers], [active_customer_prev_month], 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI_measures
		lineageTag: 2715454e-09da-470d-922b-fbb6f24da22f

	measure tooltip_avg_approval_lag = ```
			
