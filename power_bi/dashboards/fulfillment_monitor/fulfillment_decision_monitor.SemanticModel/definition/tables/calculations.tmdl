	measure top_15_filter_color = ```
			
			VAR CurrentRank = 
			    RANKX(
			        ALLSELECTED('seller_dim'[seller_id_int]),
			        [latency_slippage],
			        ,
			        DESC,
			        Dense
			    )
			RETURN 
			    IF(CurrentRank <= 15, "#5C86A8", "#BBBBBE")
			```
		displayFolder: visual_measures
		lineageTag: 2349a8a2-63f6-4db4-8a46-231f5d4cc6c1

	measure is_outlier_global =
			
			CALCULATE(
			    [is_outlier],
			    ALLSELECTED(calendar_dates)
			)
		formatString: 0
		displayFolder: visual_measures
		lineageTag: c908f2d0-f3df-4583-9866-998dea86632d

	measure matrix_slippage_tracker = ```
			
			VAR global_flag = [is_outlier_global]
			VAR cell_slippage = [latency_current_week] - [latency_4w_rolling_avg]
			VAR result = 
			    IF(
			        global_flag = 1 &&
			        cell_slippage > 0,
			        cell_slippage,
			        BLANK()
			    )
			RETURN
			    result
			```
		displayFolder: visual_measures
